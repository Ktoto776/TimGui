            "args":[{
                    "name":"PropertyName",
                    "type":"string",
                    "description":"Имя свойства, если нету устанавливает всё",
                    "required":false
                },{
                    "name":"resetToDefault",
                    "type":"boolean",
                    "description":"Сбрасывать ли для стандартного, если не указано/nil будет восприниматься как true",
