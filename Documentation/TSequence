{
    "description":"Класс для установки порядка исполнения(например, порядок языков)",
    "type":"class",
    "classes":["TClass","TGuiObject","ButtonObject","TSequence"],
    "writeSameMode":true,
    "deprecated":false,
    "properties":{
        "Type":{
            "type":"string",
            "description":"Равен \"Sequence\". Нужен для определения типа обьекта",
            "canChange":false,
            "deprecated":false
        },"Opened":{
            "type":"boolean",
            "description":"Открыт ли",
            "canChange":false,
            "deprecated":false
        },"Size":{
            "type":"UDim2",
            "description":"Размер",
            "canChange":false,
            "deprecated":false
        },"IndentBind":{
            "type":"Bind",
            "description":"Бинд для кастомного отступа. Параметры: TSequence:TSequence, VisibleIndent: Frame, SequenceFrame: Frame",
            "canChange":false,
            "deprecated":false
        },"OpenLabel":{
            "type":"Instance: ImageLabel",
            "description":"Стрелочка статуса открытия",
            "canChange":false,
            "deprecated":false
        },"SpecialOpenArrowBind":{
            "type":"Bind",
            "description":"Бинд для анимации стрелочки. Работает как в Binder.SequenceOpenArrowBind",
            "canChange":false,
            "deprecated":false
        },"SpecialCreateObject":{
            "type":"Bind",
            "description":"Бинд для создания обьектов в TSequence. Работает как в Binder.SequenceCreateObject",
            "canChange":false,
            "deprecated":false
        },"SequenceFrame":{
            "type":"Instance: Frame",
            "description":"Frame со всеми кнопками",
            "canChange":false,
            "deprecated":false
        }
    }, 
    "methods":{
        "SetObjectPosition":{
            "description":"Изменяет позицию для обьекта в TSequence",
            "args":[{
                    "name":"Name",
                    "type":"string",
                    "description":"Имя обьекта",
                    "required":true
                },{
                    "name":"New position",
                    "type":"number",
                    "description":"Позиция",
                    "required":true
                }
            ],
            "return":[{
                    "name":"success",
                    "type":"boolean",
                    "description":"Успешно ли(обычно возвращает false, если обьекта не существует)"
                }
            ], "deprecated":false
        },"AddObject":{
            "description":"Добавляет обьект",
            "args":[{
                    "name":"Name",
                    "type":"string",
                    "description":"Имя обьекта",
                    "required":true
                },{
                    "name":"Title",
                    "type":"string | {[string]:string} | Translator?",
                    "description":"Название которое видит пользователь",
                    "required":false
                }
            ],
            "return":[{
                    "name":"success",
                    "type":"boolean",
                    "description":"Успешно ли(обычно возвращает false, если обьект уже существует)"
                }
            ], "deprecated":false
        }
    }, 
    "events":{
        "OnOpen":{
            "description":"При открытии группы",
            "type":"RBXScriptEvent",
            "args":[],
            "deprecated":false
        },"OnClose":{
            "description":"При закрытии группы",
            "type":"RBXScriptEvent",
            "args":[],
            "deprecated":false
        }
    }
}